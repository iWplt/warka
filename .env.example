# --- Prisma + NextAuth (new stack — enable when ready) ---
# USE_PRISMA_AUTH=true
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# AUTH_SECRET=generate-with-openssl-rand-base64-32

# --- Local mode (no Supabase) ---
# Must be set explicitly to "true" — missing/unset means local auth is OFF.
LOCAL_AUTH_ENABLED=true
NEXT_PUBLIC_LOCAL_AUTH_ENABLED=true
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123
LOCAL_AUTH_SECRET=change-this-local-secret-key

# --- Supabase (optional — for real data) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Homepage hero image (optional — defaults to /assets/landing/hero-image.jpg)
# NEXT_PUBLIC_LANDING_HERO_IMAGE=/assets/landing/hero-image.jpg

# --- Public contact info (data-driven — footer/contact hide if unset) ---
# No fake placeholders are shown; set these to the real business details.
# NEXT_PUBLIC_CONTACT_PHONE=+9647XXXXXXXXX
# NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=+964 7XX XXX XXXX
# NEXT_PUBLIC_CONTACT_EMAIL=hello@yourdomain.com
# Business WhatsApp number (floating button + wa.me links hide if unset)
# NEXT_PUBLIC_WHATSAPP_NUMBER=9647XXXXXXXXX

# --- Uploads & email (Phase 6+) ---
# UPLOADTHING_TOKEN=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Graduation Shop <orders@yourdomain.com>

# --- WhatsApp notifications (Phase 4 Milestone A) ---
# Choose one provider — Twilio OR Meta Cloud API (not both required)
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# WHATSAPP_CLOUD_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# --- Cron jobs (Vercel) ---
# REQUIRED — cron returns 503 without it (no fallback)
CRON_SECRET=generate-a-long-random-secret-min-16-chars

# --- Auth hardening (REQUIRED — no defaults) ---
STUDENT_AUTH_PEPPER=generate-with-openssl-rand-base64-32
# LOCAL_AUTH_SECRET=generate-with-openssl-rand-base64-32
# Never enable LOCAL_AUTH_ENABLED=true on a public production deploy with default passwords.

# First-admin /setup route — OFF unless explicitly true (production must stay false)
ALLOW_BOOTSTRAP=false
