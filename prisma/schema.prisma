// Graduation Print Shop — Prisma schema (3 roles: ADMIN, REPRESENTATIVE, STUDENT)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  REPRESENTATIVE
  STUDENT
}

enum OrderType {
  SASH
  CAP
  GOWN
  CUSTOM
  GROUP
}

enum OrderStatus {
  NEW_ORDER
  WAITING_REVIEW
  DESIGNING
  WAITING_APPROVAL
  NEEDS_MODIFICATION
  READY_FOR_PRINTING
  PRINTING
  PRINTED
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ZAIN_CASH
}

enum DesignTemplateType {
  SASH
  CAP
  GOWN
  CUSTOM
}

enum DesignRequestType {
  NEW
  MODIFICATION
}

enum DesignRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  ORDER_CREATED
  STATUS_CHANGED
  DESIGN_UPLOADED
  DESIGN_APPROVED
  PAYMENT_RECORDED
  READY_FOR_DELIVERY
  GENERAL
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student        Student?
  representative Representative?
  notifications  Notification[]
  statusChanges  OrderStatusHistory[]
  designRequests DesignRequest[]

  @@index([role])
  @@index([isActive])
}

model Student {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  college          String?
  department       String?
  stage            String?
  className        String?
  graduationYear   Int?
  size             String?
  sashColor        String?
  capType          String?
  representativeId String?
  representative   Representative? @relation(fields: [representativeId], references: [id], onDelete: SetNull)
  orders           Order[]
  designRequests   DesignRequest[]

  @@index([representativeId])
}

model Representative {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  college        String?
  department     String?
  graduationYear Int?
  students       Student[]
  orders         Order[]
}

model Order {
  id               String         @id @default(cuid())
  orderNumber      String         @unique
  studentId        String?
  student          Student?       @relation(fields: [studentId], references: [id], onDelete: SetNull)
  representativeId String?
  representative   Representative? @relation(fields: [representativeId], references: [id], onDelete: SetNull)
  type             OrderType
  status           OrderStatus    @default(NEW_ORDER)
  paymentStatus    PaymentStatus  @default(UNPAID)
  paymentMethod    PaymentMethod?
  totalPrice       Decimal        @db.Decimal(12, 2)
  paidAmount       Decimal        @default(0) @db.Decimal(12, 2)
  notes            String?
  adminNotes       String?
  qrCode           String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  items          OrderItem[]
  statusHistory  OrderStatusHistory[]
  notifications  Notification[]
  designRequests DesignRequest[]

  @@index([status])
  @@index([paymentStatus])
  @@index([studentId])
  @@index([representativeId])
  @@index([createdAt])
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productType      OrderType
  quantity         Int             @default(1)
  size             String?
  color            String?
  customText       String?
  logoUrl          String?
  designTemplateId String?
  designTemplate   DesignTemplate? @relation(fields: [designTemplateId], references: [id], onDelete: SetNull)
  price            Decimal         @db.Decimal(12, 2)

  @@index([orderId])
}

model DesignTemplate {
  id           String             @id @default(cuid())
  name         String
  type         DesignTemplateType
  previewUrl   String?
  templateData Json
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())

  orderItems OrderItem[]

  @@index([type, isActive])
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  user       User?        @relation(fields: [changedBy], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime     @default(now())

  @@index([orderId, createdAt])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  message        String
  type           NotificationType @default(GENERAL)
  isRead         Boolean          @default(false)
  relatedOrderId String?
  relatedOrder   Order?           @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model DesignRequest {
  id                String              @id @default(cuid())
  orderId           String
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedById     String?
  requestedBy       User?               @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  requestType       DesignRequestType
  description       String?
  referenceImages   Json                @default("[]")
  status            DesignRequestStatus @default(PENDING)
  designPreviewUrl  String?
  studentApproved   Boolean             @default(false)
  createdAt         DateTime            @default(now())

  @@index([orderId])
  @@index([studentId])
}

model Price {
  id          String             @id @default(cuid())
  productType DesignTemplateType @unique
  basePrice   Decimal            @db.Decimal(12, 2)
  description String?
  isActive    Boolean            @default(true)
}

model BulkLead {
  id              String   @id @default(cuid())
  university      String
  studentCount    Int
  coordinatorName String
  phone           String
  email           String?
  products        Json
  notes           String?
  createdAt       DateTime @default(now())

  @@index([createdAt])
}
